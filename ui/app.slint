export component App inherits Window {
    width: 320px;
    height: 240px;
    title: "ESP32-S3-BOX Slint";

    in-out property <int> counter: 0;

    Rectangle {
        background: #1f2937;

        VerticalLayout {
            alignment: center;
            spacing: 16px;

            Text {
                text: "Hello Slint on ESP32-S3";
                color: white;
                font-size: 20px;
                horizontal-alignment: center;
            }

            Text {
                text: "Counter: " + root.counter;
                color: #93c5fd;
                font-size: 18px;
                horizontal-alignment: center;
            }

            TouchArea {
                clicked => {
                    root.counter += 1;
                }

                Rectangle {
                    width: 160px;
                    height: 48px;
                    border-radius: 8px;
                    background: #2563eb;

                    Text {
                        text: "Tap Me";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}