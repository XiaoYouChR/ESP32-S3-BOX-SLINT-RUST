export component App inherits Window {
    width: 320px;
    height: 240px;

    in-out property <int> counter: 0;
    in-out property <int> long-press-count: 0;
    in-out property <string> last-gesture: "Idle";
    in-out property <length> dot-x: 160px;
    in-out property <length> dot-y: 120px;

    Rectangle {
        background: #1f2937;

        TouchArea {
            moved => {
                root.dot-x = self.mouse-x;
                root.dot-y = self.mouse-y;
            }

            clicked => {
                root.counter += 1;
                root.last-gesture = "Click";
            }
        }

        Rectangle {
            x: root.dot-x - 10px;
            y: root.dot-y - 10px;
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: #2563eb;
        }

        Text {
            text: "Clicks: " + root.counter + "  Long: " + root.long-press-count;
            color: white;
            font-size: 18px;
            x: 10px;
            y: 10px;
        }

        Text {
            text: "Last: " + root.last-gesture;
            color: #d1d5db;
            font-size: 16px;
            x: 10px;
            y: 34px;
        }
    }
}
